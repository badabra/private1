@page
@model Minima.Pages.LoginModel
@{
    ViewData["Title"] = "Connexion";
}

<div class="flex min-h-screen items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md bg-white p-8 rounded-xl shadow-lg border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Connexion à Minima</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
                <strong>Erreur:</strong> @Model.ErrorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
                <strong>Succès:</strong> @Model.SuccessMessage
            </div>
        }

        <form method="POST">
            <!-- Champ : Identifiant ou Courriel -->
            <div class="flex flex-wrap -mx-3 mb-5">
                <div class="w-full px-3">
                    <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="login-username">
                        Identifiant ou Adresse courriel
                    </label>
                    <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors" 
                           id="login-username" asp-for="UsernameOrEmail" type="text" required>
                </div>
            </div>

            <!-- Champ : Mot de passe -->
            <div class="flex flex-wrap -mx-3 mb-6">
                <div class="w-full px-3">
                    <div class="flex justify-between items-center mb-2">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold" for="login-password">
                            Mot de passe
                        </label>
                    </div>
                    <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors" 
                           id="login-password" asp-for="Password" type="password" placeholder="********" required>
                </div>
            </div>

            <!-- Bouton de connexion -->
            <div class="flex flex-wrap -mx-3 mt-6">
                <div class="w-full px-3">
                    <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg focus:outline-none focus:shadow-outline transition duration-150 ease-in-out shadow-md" 
                            type="submit">
                        Se connecter
                    </button>
                </div>
            </div>

            <!-- Lien vers l'inscription -->
            <div class="text-center mt-6">
                <p class="text-sm text-gray-600">
                    Nouveau sur Minima ?
                    <a asp-page="/Register" class="text-blue-600 hover:underline font-medium">Créer un compte</a>
                </p>
            </div>
        </form>
    </div>
</div>