@page
@model Minima.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Réinitialiser le mot de passe";
}

<div class="flex min-h-screen items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md bg-white p-8 rounded-xl shadow-lg border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Nouveau mot de passe</h2>

        @if (!Model.TokenValid)
        {
            <div class="mb-4 p-3 bg-red-100 border border-red-300 text-red-800 rounded-lg text-sm">
                Ce lien de réinitialisation est invalide, expiré ou déjà utilisé.
            </div>
            <div class="text-center">
                <a asp-page="/ForgotPassword" class="text-blue-600 hover:underline font-medium">
                    Générer un nouveau lien
                </a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-4 p-3 bg-red-100 border border-red-300 text-red-800 rounded-lg text-sm">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <input type="hidden" asp-for="Token" />

                <div class="flex flex-wrap -mx-3 mb-4">
                    <div class="w-full px-3">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="reset-password">
                            Nouveau mot de passe
                        </label>
                        <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                               id="reset-password" name="Password" type="password" placeholder="********" required>
                        <p class="text-gray-400 text-xs italic mt-1">Au moins 6 caractères.</p>
                    </div>
                </div>

                <div class="flex flex-wrap -mx-3 mb-6">
                    <div class="w-full px-3">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="reset-confirm">
                            Confirmer le mot de passe
                        </label>
                        <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                               id="reset-confirm" name="ConfirmPassword" type="password" placeholder="********" required>
                    </div>
                </div>

                <div class="flex flex-wrap -mx-3">
                    <div class="w-full px-3">
                        <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg focus:outline-none transition duration-150 ease-in-out shadow-md"
                                type="submit">
                            Réinitialiser le mot de passe
                        </button>
                    </div>
                </div>
            </form>
        }
    </div>
</div>
