@page
@model IndexModel
@{
    ViewData["Title"] = "Accueil";
}

<div class="max-w-5xl mx-auto px-4">

    <!-- Héro -->
    <section class="text-center pt-20 pb-16">
        <span class="inline-block mb-4 px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-xs font-semibold tracking-wide">
            Messagerie privée &middot; sans publicité
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight leading-tight">
            Discutez librement,<br class="hidden sm:block" />
            <!--<span class="text-blue-600">sans numéro de téléphone</span>-->
            <span class="text-blue-600">en toute confidentialité</span>
        </h1>
        <p class="mt-5 text-lg text-gray-500 max-w-2xl mx-auto">
            Minima est une plateforme de messagerie sobre et sécurisée, pensée pour les écoles
            et les organisations, hébergeable sur vos propres serveurs.
        </p>

        <div class="mt-8 flex items-center justify-center gap-3">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-page="/Contacts"
                   class="px-6 py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 shadow-md transition">
                    Ouvrir mes discussions
                </a>
                <a asp-page="/Dashboard"
                   class="px-6 py-3 rounded-xl bg-white text-gray-700 font-semibold border border-gray-200 hover:bg-gray-50 transition">
                    Tableau de bord
                </a>
            }
            else
            {
                <a asp-page="/Register"
                   class="px-6 py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 shadow-md transition">
                    Créer un compte
                </a>
                <a asp-page="/Login"
                   class="px-6 py-3 rounded-xl bg-white text-gray-700 font-semibold border border-gray-200 hover:bg-gray-50 transition">
                    Se connecter
                </a>
            }
        </div>
    </section>

    <!-- Points forts -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-4 pb-20">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                </svg>
            </div>
            <h3 class="font-bold text-gray-900">Sécurisé par conception</h3>
            <p class="mt-1.5 text-sm text-gray-500">
                Mots de passe hachés avec BCrypt, accès protégés par jetons JWT. Vos données restent chez vous.
            </p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
            </div>
            <h3 class="font-bold text-gray-900">Temps réel</h3>
            <p class="mt-1.5 text-sm text-gray-500">
                Messages, fichiers, réactions et statut en ligne — tout arrive instantanément, sans rafraîchir la page.
            </p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z" />
                </svg>
            </div>
            <h3 class="font-bold text-gray-900">Hébergement local</h3>
            <p class="mt-1.5 text-sm text-gray-500">
                Déployez Minima sur les serveurs de votre école ou entreprise. Aucune dépendance à un service externe.
            </p>
        </div>
    </section>
</div>
