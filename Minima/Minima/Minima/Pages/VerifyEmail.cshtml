@page
@model Minima.Pages.VerifyEmailModel
@{
    ViewData["Title"] = "Vérification de l'email";
}

<div class="flex min-h-[80vh] items-center justify-center py-12 px-4">
    <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
        <h2 class="text-2xl font-extrabold text-gray-900 tracking-tight mb-2 text-center">Vérifiez votre email</h2>
        <p class="text-sm text-gray-500 mb-6 text-center">
            Un code à 6 chiffres a été envoyé à<br />
            <span class="font-semibold text-gray-700">@Model.Email</span>
        </p>

        @if (!string.IsNullOrEmpty(Model.InfoMessage))
        {
            <div class="mb-4 p-3 bg-green-100 border border-green-300 text-green-800 rounded-xl text-sm">
                @Model.InfoMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-4 p-3 bg-red-100 border border-red-300 text-red-800 rounded-xl text-sm">
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <input type="hidden" asp-for="Email" />
            <div class="mb-6">
                <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="code">
                    Code de vérification
                </label>
                <input id="code" name="Code" inputmode="numeric" maxlength="6" autocomplete="one-time-code"
                       class="block w-full text-center text-2xl tracking-[0.5em] font-bold bg-gray-50 text-gray-800 border border-gray-200 rounded-xl py-3 px-4 focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                       placeholder="______" required>
            </div>

            <button type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-xl transition duration-150 shadow-md">
                Activer mon compte
            </button>
        </form>

        <form method="post" asp-page-handler="Resend" class="mt-4 text-center">
            <input type="hidden" asp-for="Email" />
            <p class="text-sm text-gray-500">
                Vous n'avez pas reçu le code ?
                <button type="submit" class="text-blue-600 hover:underline font-medium">Renvoyer un code</button>
            </p>
        </form>

        <div class="text-center mt-6">
            <a asp-page="/Login" class="text-sm text-gray-400 hover:text-gray-600">&larr; Retour à la connexion</a>
        </div>
    </div>
</div>
