@page
@model Minima.Pages.ProfileModel
@{
    ViewData["Title"] = "Mon compte";
}

<div class="min-h-screen bg-gray-50 py-12 px-4">
    <div class="max-w-2xl mx-auto space-y-6">

        <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-8">
            <h1 class="text-2xl font-bold text-gray-900">Mon compte</h1>
            <p class="text-gray-500 text-sm mt-1">Identifiant : <span class="font-medium text-gray-700">@Model.Username</span> (non modifiable)</p>
        </div>

        <!-- Modifier mes informations -->
        <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-8">
            <h2 class="text-xl font-bold text-gray-900 mb-4">Mes informations</h2>

            @if (!string.IsNullOrEmpty(Model.InfoMessage))
            {
                <div class="mb-4 p-3 bg-green-100 border border-green-300 text-green-800 rounded-lg text-sm">
                    @Model.InfoMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.InfoError))
            {
                <div class="mb-4 p-3 bg-red-100 border border-red-300 text-red-800 rounded-lg text-sm">
                    @Model.InfoError
                </div>
            }

            <form method="post" asp-page-handler="Info">
                <div class="flex flex-wrap -mx-3 mb-4">
                    <div class="w-full md:w-1/2 px-3 mb-4 md:mb-0">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="profile-first">
                            Prénom
                        </label>
                        <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                               id="profile-first" name="FirstName" value="@Model.FirstName" type="text" required>
                    </div>
                    <div class="w-full md:w-1/2 px-3">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="profile-last">
                            Nom
                        </label>
                        <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                               id="profile-last" name="LastName" value="@Model.LastName" type="text" required>
                    </div>
                </div>

                <div class="flex flex-wrap -mx-3 mb-6">
                    <div class="w-full px-3">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="profile-email">
                            Adresse courriel
                        </label>
                        <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                               id="profile-email" name="Email" value="@Model.Email" type="email" required>
                    </div>
                </div>

                <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg transition duration-150 shadow-md"
                        type="submit">
                    Enregistrer mes informations
                </button>
            </form>
        </div>

        <!-- Changer mon mot de passe -->
        <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-8">
            <h2 class="text-xl font-bold text-gray-900 mb-4">Changer mon mot de passe</h2>

            @if (!string.IsNullOrEmpty(Model.PasswordMessage))
            {
                <div class="mb-4 p-3 bg-green-100 border border-green-300 text-green-800 rounded-lg text-sm">
                    @Model.PasswordMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.PasswordError))
            {
                <div class="mb-4 p-3 bg-red-100 border border-red-300 text-red-800 rounded-lg text-sm">
                    @Model.PasswordError
                </div>
            }

            <form method="post" asp-page-handler="Password">
                <div class="flex flex-wrap -mx-3 mb-4">
                    <div class="w-full px-3">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="profile-current">
                            Mot de passe actuel
                        </label>
                        <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                               id="profile-current" name="CurrentPassword" type="password" placeholder="********" required>
                    </div>
                </div>

                <div class="flex flex-wrap -mx-3 mb-6">
                    <div class="w-full md:w-1/2 px-3 mb-4 md:mb-0">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="profile-new">
                            Nouveau mot de passe
                        </label>
                        <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                               id="profile-new" name="NewPassword" type="password" placeholder="********" required>
                    </div>
                    <div class="w-full md:w-1/2 px-3">
                        <label class="block uppercase tracking-wide text-gray-700 text-xs font-bold mb-2" for="profile-confirm">
                            Confirmer
                        </label>
                        <input class="appearance-none block w-full bg-gray-50 text-gray-700 border border-gray-200 rounded-lg py-3 px-4 leading-tight focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                               id="profile-confirm" name="ConfirmNewPassword" type="password" placeholder="********" required>
                    </div>
                </div>

                <button class="w-full bg-gray-800 hover:bg-gray-900 text-white font-bold py-3 px-4 rounded-lg transition duration-150 shadow-md"
                        type="submit">
                    Changer le mot de passe
                </button>
            </form>
        </div>
    </div>
</div>
