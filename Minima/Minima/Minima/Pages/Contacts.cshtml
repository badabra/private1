@page
@model Minima.Pages.ContactsModel
@{
    ViewData["Title"] = "Contacts";
}

<div class="py-12 px-4">
    <div class="max-w-3xl mx-auto space-y-6">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="p-3 bg-green-100 border border-green-300 text-green-800 rounded-xl text-sm">
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- CONTACT-01 : recherche -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-xl font-extrabold text-gray-900 tracking-tight mb-4">Rechercher un utilisateur</h2>
            <form method="post" asp-page-handler="Search" class="flex gap-2">
                <input name="SearchTerm" value="@Model.SearchTerm"
                       class="flex-1 bg-gray-50 text-gray-700 border border-gray-200 rounded-xl py-2.5 px-4 focus:outline-none focus:bg-white focus:border-blue-500 transition-colors"
                       placeholder="Identifiant, nom ou courriel..." />
                <button type="submit"
                        class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-5 rounded-xl transition duration-150">
                    Rechercher
                </button>
            </form>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <p class="mt-3 text-sm text-red-600">@Model.ErrorMessage</p>
            }

            @if (Model.SearchResults.Count > 0)
            {
                <ul class="mt-4 divide-y divide-gray-100">
                    @foreach (var u in Model.SearchResults)
                    {
                        <li class="py-3 flex items-center justify-between gap-3">
                            <div class="flex items-center gap-3 min-w-0">
                                <span class="w-10 h-10 rounded-full bg-gray-100 text-gray-600 font-bold flex items-center justify-center shrink-0">
                                    @(u.Username.Substring(0, 1).ToUpper())
                                </span>
                                <div class="min-w-0">
                                    <p class="font-semibold text-gray-900 truncate">@u.Username</p>
                                    <p class="text-sm text-gray-500 truncate">@u.FirstName @u.LastName</p>
                                </div>
                            </div>
                            @if (Model.MyContactIds.Contains(u.Id))
                            {
                                <span class="text-sm text-gray-400 shrink-0">Déjà ajouté</span>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Add">
                                    <input type="hidden" name="userId" value="@u.Id" />
                                    <button type="submit"
                                            class="bg-blue-50 text-blue-700 hover:bg-blue-100 text-sm font-semibold py-2 px-4 rounded-xl transition duration-150 shrink-0">
                                        + Ajouter
                                    </button>
                                </form>
                            }
                        </li>
                    }
                </ul>
            }
        </div>

        <!-- CONTACT-02 : liste de mes contacts -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-xl font-extrabold text-gray-900 tracking-tight mb-4">Mes contacts (@Model.MyContacts.Count)</h2>

            @if (Model.MyContacts.Count == 0)
            {
                <p class="text-gray-500 text-sm">Aucun contact pour l'instant. Utilisez la recherche ci-dessus pour en ajouter.</p>
            }
            else
            {
                <ul class="divide-y divide-gray-100">
                    @foreach (var c in Model.MyContacts)
                    {
                        <li class="py-3 flex items-center justify-between gap-3">
                            <div class="flex items-center gap-3 min-w-0">
                                <span class="w-10 h-10 rounded-full bg-blue-100 text-blue-700 font-bold flex items-center justify-center shrink-0">
                                    @(c.ContactUser.Username.Substring(0, 1).ToUpper())
                                </span>
                                <div class="min-w-0">
                                    <p class="font-semibold text-gray-900 truncate">@c.ContactUser.Username</p>
                                    <p class="text-sm text-gray-500 truncate">@c.ContactUser.FirstName @c.ContactUser.LastName</p>
                                </div>
                            </div>
                            <a asp-page="/Chat" asp-route-userId="@c.ContactUserId"
                               class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold py-2 px-4 rounded-xl transition duration-150 shrink-0">
                                Discuter
                            </a>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>
