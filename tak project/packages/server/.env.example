# Port d'écoute de l'API
PORT=4000

# Chaîne de connexion MongoDB Atlas (à créer sur cloud.mongodb.com)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/takhub

# Secret utilisé pour signer les jetons JWT (chaîne longue et aléatoire)
JWT_SECRET=change-me

